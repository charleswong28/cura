// Prisma Schema - Cura CRM
// ID Strategy: ULIDs generated at the application layer using the `ulid` npm package.
// All @id fields use String type; IDs are passed in by services before create/upsert calls.
// See src/common/ulid.ts for the generateId() utility.
//
// Prisma 7: Connection URL is configured in prisma.config.ts (not here).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum CandidateStatus {
  ACTIVE
  INACTIVE
  PLACED
  BLACKLISTED
}

enum ClientStatus {
  PROSPECT
  ACTIVE
  INACTIVE
}

enum JobStatus {
  OPEN
  ON_HOLD
  FILLED
  CLOSED
}

enum JobPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ActivityAction {
  USER_UPDATED_PROFILE
  USER_ROLE_CHANGED
  USER_INVITED
  USER_INVITATION_REVOKED
  USER_DEACTIVATED
  USER_REACTIVATED
}

// ---------------------------------------------------------------------------
// EPIC-002: Auth & Permission Enums
// ---------------------------------------------------------------------------

enum TeamKind {
  BUSINESS  // sales team, practice group, desk
  REGION    // APAC, EMEA, Americas
  PRACTICE  // Healthcare, Technology, Finance
  OTHER
}

enum TeamRole {
  LEAD    // team manager — grants LEAD-level on permission resolution
  MEMBER  // standard member
}

enum DataScopeType {
  ALL        // see every record in the tenant (admin)
  TEAM_TREE  // see records owned by my teams + all descendant teams
  MY_TEAMS   // see records owned by my direct teams only (no descendants)
  MINE       // see only records where ownerUserId = me
  EXPLICIT   // see only records with an explicit Permission grant
}

enum GranteeType {
  USER
  TEAM
  ROLE
}

enum AccessLevel {
  VIEW
  EDIT
  OWNER
}

enum GrantSource {
  DIRECT     // manually granted by a user
  INHERITED  // from PermissionInheritance graph
  RULE       // system auto-grant on record creation (§5.5)
  APPROVAL   // triggered by an approval flow
}

enum GrantAction {
  GRANT
  UPGRADE
  DOWNGRADE
  REVOKE
}

// ---------------------------------------------------------------------------
// CRM Pipeline Enums
// ---------------------------------------------------------------------------

enum ApplicationStageType {
  APPLIED
  LONGLIST
  CV_SENT
  INTERVIEW
  OFFER
  PLACEMENT
  REJECTED
}

enum LanguageProficiency {
  BASIC
  CONVERSATIONAL
  PROFESSIONAL
  NATIVE
}

enum FeeType {
  FLAT
  PERCENTAGE
}

enum MigrationStatus {
  ACTIVE    // crons running, Cura domain mutations are read-only
  CUTOVER   // cutover completed, Cura is fully writable
  DISABLED  // migration module disabled
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

/// Represents a headhunting firm / organisation (the tenant boundary).
model Tenant {
  id        String   @id
  slug      String   @unique // used for multi-tenant login (tenantSlug in JWT)
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users        User[]
  clients      Client[]
  candidates   Candidate[]
  jobs         Job[]
  activityLogs ActivityLog[]

  @@map("tenants")
}

/// Recruiter or admin belonging to a tenant. One AuthIdentity → many Users (one per tenant).
model User {
  id             String        @id
  tenantId       String        @map("tenant_id")
  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  authIdentityId String?       @unique @map("auth_identity_id")
  authIdentity   AuthIdentity? @relation(fields: [authIdentityId], references: [id])
  email          String
  firstName      String        @map("first_name")
  lastName       String        @map("last_name")
  loginable      Boolean       @default(true) // false = deactivated
  firstLogin     DateTime?     @map("first_login")
  lastInactiveAt DateTime?     @map("last_inactive_at")
  deletedAt      DateTime?     @map("deleted_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  sessions          Session[]
  userRoles         UserRole[]
  teamMemberships   TeamMember[]
  assignedJobs      Job[]       @relation("JobAssignee")
  ownedJobs         Job[]       @relation("JobOwner")
  createdJobs       Job[]       @relation("JobCreator")
  ownedCandidates   Candidate[] @relation("CandidateOwner")
  createdCandidates Candidate[] @relation("CandidateCreator")
  bdClients         Client[]    @relation("ClientBD")
  createdClients    Client[]    @relation("ClientCreator")
  activityLogs      ActivityLog[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

// ---------------------------------------------------------------------------
// EPIC-002 — Auth Identity & Credential Models (TASK-065)
// ---------------------------------------------------------------------------

/// Credential store — one per person, shared across tenants.
/// AuthIdentity holds credentials; User holds the operational profile per tenant.
model AuthIdentity {
  id               String    @id
  email            String    @unique
  passwordHash     String    @map("password_hash")
  oidcSubject      String?   @unique @map("oidc_subject")
  failedLoginCount Int       @default(0) @map("failed_login_count")
  lockedUntil      DateTime? @map("locked_until")   // set after 5 consecutive fails
  mfaEnrolled      Boolean   @default(false) @map("mfa_enrolled")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  users               User[]
  sessions            Session[]
  mfaDevices          MfaDevice[]
  passwordResetTokens PasswordResetToken[]
  passwordHistory     PasswordHistory[]

  @@map("auth_identities")
}

/// Refresh-token sessions. One auth identity can have many active sessions (multi-device).
model Session {
  id               String       @id
  authIdentityId   String       @map("auth_identity_id")
  authIdentity     AuthIdentity @relation(fields: [authIdentityId], references: [id])
  userId           String       @map("user_id")      // the User (tenant-scoped) for this session
  user             User         @relation(fields: [userId], references: [id])
  refreshTokenHash String       @unique @map("refresh_token_hash")
  ip               String?
  userAgent        String?      @map("user_agent")
  expiresAt        DateTime     @map("expires_at")   // +90 days from creation
  revokedAt        DateTime?    @map("revoked_at")   // set on logout / reuse detection
  lastUsedAt       DateTime?    @map("last_used_at")
  createdAt        DateTime     @default(now()) @map("created_at")

  @@index([authIdentityId])
  @@index([userId])
  @@map("sessions")
}

/// TOTP device for an AuthIdentity. One identity may have at most one active MFA device.
model MfaDevice {
  id                String       @id
  authIdentityId    String       @map("auth_identity_id")
  authIdentity      AuthIdentity @relation(fields: [authIdentityId], references: [id])
  secretEncrypted   String       @map("secret_encrypted") // AES-256-GCM; key from env
  backupCodesHashed String[]     @map("backup_codes_hashed") // argon2id(code); deleted on use
  enrolledAt        DateTime     @default(now()) @map("enrolled_at")
  lastVerifiedAt    DateTime?    @map("last_verified_at")

  @@index([authIdentityId])
  @@map("mfa_devices")
}

/// One-time tokens for the forgot-password flow. Stored as hashes; raw token is emailed.
model PasswordResetToken {
  id             String       @id
  authIdentityId String       @map("auth_identity_id")
  authIdentity   AuthIdentity @relation(fields: [authIdentityId], references: [id])
  tokenHash      String       @unique @map("token_hash")
  expiresAt      DateTime     @map("expires_at")   // +1 hour
  usedAt         DateTime?    @map("used_at")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([authIdentityId])
  @@map("password_reset_tokens")
}

/// Previous password hashes for history enforcement. Capped at PasswordPolicy.historySize.
model PasswordHistory {
  id             String       @id
  authIdentityId String       @map("auth_identity_id")
  authIdentity   AuthIdentity @relation(fields: [authIdentityId], references: [id])
  passwordHash   String       @map("password_hash")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([authIdentityId])
  @@map("password_history")
}

/// Tenant-level or global password complexity and history policy.
model PasswordPolicy {
  id            String  @id
  tenantId      String? @unique @map("tenant_id") // null = global default
  minLength     Int     @default(8) @map("min_length")
  requireUpper  Boolean @default(true) @map("require_upper")
  requireLower  Boolean @default(true) @map("require_lower")
  requireDigit  Boolean @default(true) @map("require_digit")
  requireSymbol Boolean @default(false) @map("require_symbol")
  historySize   Int     @default(5) @map("history_size") // how many old passwords to check

  @@map("password_policies")
}

// ---------------------------------------------------------------------------
// EPIC-002 — Role & Functional Permission Models (TASK-066)
// ---------------------------------------------------------------------------

/// Functional role — holds a set of permission strings (e.g. "candidate:view_all").
/// Built-in roles have tenantId = null and cannot be modified.
/// Tenants can define custom roles by setting tenantId.
model Role {
  id          String    @id
  shortId     Int       @unique @default(autoincrement()) @map("short_id") // compact JWT encoding
  tenantId    String?   @map("tenant_id")   // null = system-wide built-in
  name        String
  description String?
  permissions Json      // string[] — e.g. ["candidate:view_all", "job:create"]
  builtin     Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  userRoles  UserRole[]
  dataScopes RoleDataScope[]

  @@unique([tenantId, name])
  @@map("roles")
}

/// Junction table: user ↔ role assignment.
model UserRole {
  userId       String
  roleId       String
  assignedAt   DateTime @default(now()) @map("assigned_at")
  assignedById String   @map("assigned_by_id")
  user         User     @relation(fields: [userId], references: [id])
  role         Role     @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

/// Per-resource default visibility scope for each role (drives list-query filtering).
model RoleDataScope {
  roleId       String        @map("role_id")
  resourceType String        @map("resource_type") // 'Candidate' | 'Job' | 'Client' | ...
  dataScope    DataScopeType @map("data_scope")
  role         Role          @relation(fields: [roleId], references: [id])

  @@id([roleId, resourceType])
  @@map("role_data_scopes")
}

// ---------------------------------------------------------------------------
// EPIC-002 — Team Structure (TASK-067)
// ---------------------------------------------------------------------------

/// Self-referential team tree. `kind` replaces Gllue's team / team2 / team3 trio.
/// shortId is a compact int used in JWT `teams` claim for space efficiency.
model Team {
  id        String    @id
  shortId   Int       @unique @default(autoincrement()) @map("short_id") // immutable; JWT encoding
  tenantId  String    @map("tenant_id")
  parentId  String?   @map("parent_id")
  parent    Team?     @relation("TeamHierarchy", fields: [parentId], references: [id])
  children  Team[]    @relation("TeamHierarchy")
  name      String
  kind      TeamKind
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  members TeamMember[]

  @@index([tenantId, kind])
  @@map("teams")
}

/// Team membership with LEAD / MEMBER role for permission resolution.
model TeamMember {
  teamId   String   @map("team_id")
  userId   String   @map("user_id")
  role     TeamRole
  joinedAt DateTime @default(now()) @map("joined_at")
  team     Team     @relation(fields: [teamId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@id([teamId, userId])
  @@map("team_members")
}

// ---------------------------------------------------------------------------
// EPIC-002 — Row-Level Permission Models (TASK-068)
// ---------------------------------------------------------------------------

/// Per-record access grant. One row = one grantee's access to one resource.
/// Replaces Gllue's 14+ `*privilege/*uniqueprivilege` table pairs.
model Permission {
  id           String      @id
  tenantId     String      @map("tenant_id")
  granteeType  GranteeType @map("grantee_type")
  granteeId    String      @map("grantee_id")
  resourceType String      @map("resource_type") // 'Candidate' | 'Job' | 'Client' | ...
  resourceId   String      @map("resource_id")
  accessLevel  AccessLevel @map("access_level")
  grantSource  GrantSource @map("grant_source")
  expiresAt    DateTime?   @map("expires_at")
  createdAt    DateTime    @default(now()) @map("created_at")
  createdById  String      @map("created_by_id")

  @@unique([tenantId, granteeType, granteeId, resourceType, resourceId])
  @@index([tenantId, resourceType, resourceId]) // "who can access record X?"
  @@index([granteeId, tenantId, resourceType])  // "what can grantee see?"
  @@map("permissions")
}

/// Append-only audit trail for all permission changes. Never delete rows.
model PermissionGrant {
  id           String       @id
  permissionId String?      @map("permission_id") // null after revoke
  tenantId     String       @map("tenant_id")
  granteeType  GranteeType  @map("grantee_type")
  granteeId    String       @map("grantee_id")
  resourceType String       @map("resource_type")
  resourceId   String       @map("resource_id")
  action       GrantAction
  fromLevel    AccessLevel? @map("from_level")
  toLevel      AccessLevel? @map("to_level")
  reason       String?
  actorId      String       @map("actor_id")
  occurredAt   DateTime     @default(now()) @map("occurred_at")

  @@index([resourceType, resourceId, occurredAt])
  @@index([granteeId, occurredAt])
  @@map("permission_grants")
}

/// Cascade rules: access to `fromResourceType` auto-grants access to `toResourceType`.
/// Seeded at migration; see §5.4 of authn-authz-technical-plan.md.
model PermissionCascadeRule {
  id               String      @id
  fromResourceType String      @map("from_resource_type")
  toResourceType   String      @map("to_resource_type")
  minAccessLevel   AccessLevel @map("min_access_level") // min level on 'from' to trigger
  grantLevel       AccessLevel @map("grant_level")      // level granted on 'to'

  @@unique([fromResourceType, toResourceType])
  @@map("permission_cascade_rules")
}

/// Explicit inheritance graph for approval-triggered propagation.
/// When a team holds a Permission, membership changes require no graph update.
model PermissionInheritance {
  parentPermissionId String      @map("parent_permission_id")
  childGranteeType   GranteeType @map("child_grantee_type")
  childGranteeId     String      @map("child_grantee_id")

  @@id([parentPermissionId, childGranteeType, childGranteeId])
  @@map("permission_inheritances")
}

/// Magic-link token for sharing a resource with an external user (no Cura account).
model ShareToken {
  id           String      @id
  tenantId     String      @map("tenant_id")
  tokenHash    String      @unique @map("token_hash")
  resourceType String      @map("resource_type")
  resourceId   String      @map("resource_id")
  accessLevel  AccessLevel @map("access_level")
  expiresAt    DateTime    @map("expires_at")
  createdById  String      @map("created_by_id")
  createdAt    DateTime    @default(now()) @map("created_at")
  revokedAt    DateTime?   @map("revoked_at")

  @@index([tenantId, resourceType, resourceId])
  @@map("share_tokens")
}

// ---------------------------------------------------------------------------
// EPIC-002 — Audit Log (TASK-069)
// ---------------------------------------------------------------------------

/// Structured audit log for authn/authz and data events. Replaces ActivityLog long-term.
/// See §8 of authn-authz-technical-plan.md for tracked event types.
model AuditLog {
  id           String   @id
  tenantId     String?  @map("tenant_id")
  actorId      String?  @map("actor_id")           // null for system events
  actorType    String   @default("USER") @map("actor_type") // USER | SYSTEM | API_KEY
  resourceType String   @map("resource_type")
  resourceId   String   @map("resource_id")
  action       String   // 'authn.login_success' | 'permission.granted' | 'candidate.exported' | ...
  oldValue     Json?    @map("old_value")
  newValue     Json?    @map("new_value")
  ip           String?
  userAgent    String?  @map("user_agent")
  occurredAt   DateTime @default(now()) @map("occurred_at")

  @@index([tenantId, resourceType, resourceId])
  @@index([tenantId, actorId, occurredAt])
  @@index([occurredAt])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// Core CRM Models
// ---------------------------------------------------------------------------

/// A job-seeker tracked by the tenant.
model Candidate {
  id             String          @id
  tenantId       String          @map("tenant_id")
  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  ownerUserId    String?         @map("owner_user_id")     // for data-scope MINE / MY_TEAMS
  ownerUser      User?           @relation("CandidateOwner", fields: [ownerUserId], references: [id])
  createdById    String?         @map("created_by_id")
  createdBy      User?           @relation("CandidateCreator", fields: [createdById], references: [id])
  firstName      String          @map("first_name")
  lastName       String          @map("last_name")
  email          String?
  phone          String?
  currentCompany String?         @map("current_company")
  currentTitle   String?         @map("current_title")
  location       String?
  linkedinUrl    String?         @map("linkedin_url")
  githubUrl      String?         @map("github_url")
  status         CandidateStatus @default(ACTIVE)
  notes          String?
  updatedById    String?         @map("updated_by_id")
  deletedAt      DateTime?       @map("deleted_at")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  experiences  CandidateExperience[]
  educations   CandidateEducation[]
  languages    CandidateLanguage[]
  applications JobApplication[]

  // email uniqueness is per-tenant; NULLs are intentionally allowed
  @@unique([tenantId, email])
  @@index([tenantId, deletedAt])
  @@map("candidates")
}

/// A client company that posts job orders.
model Client {
  id          String       @id
  tenantId    String       @map("tenant_id")
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  bdUserId    String?      @map("bd_user_id")   // business-development owner; auto-granted OWNER
  bdUser      User?        @relation("ClientBD", fields: [bdUserId], references: [id])
  createdById String?      @map("created_by_id")
  createdBy   User?        @relation("ClientCreator", fields: [createdById], references: [id])
  name        String
  industry    String?
  website     String?
  phone       String?
  address     String?
  parentId        String?      @map("parent_id")
  parent          Client?      @relation("ClientHierarchy", fields: [parentId], references: [id])
  children        Client[]     @relation("ClientHierarchy")
  status          ClientStatus @default(PROSPECT)
  activeJobCount  Int          @default(0) @map("active_job_count")
  totalJobCount   Int          @default(0) @map("total_job_count")
  deletedAt       DateTime?    @map("deleted_at")
  updatedById     String?      @map("updated_by_id")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  jobs     Job[]
  contacts ClientContact[]

  @@index([tenantId, deletedAt])
  @@index([tenantId, bdUserId])
  @@map("clients")
}

/// An open position linked to a client company.
model Job {
  id           String      @id
  tenantId     String      @map("tenant_id")
  tenant       Tenant      @relation(fields: [tenantId], references: [id])
  clientId     String      @map("client_id")
  client       Client      @relation(fields: [clientId], references: [id])
  ownerUserId  String?     @map("owner_user_id")  // for data-scope and auto-grant EDIT
  ownerUser    User?       @relation("JobOwner", fields: [ownerUserId], references: [id])
  createdById  String?     @map("created_by_id")
  createdBy    User?       @relation("JobCreator", fields: [createdById], references: [id])
  title        String
  description      String?
  status           JobStatus   @default(OPEN)
  priority         JobPriority @default(MEDIUM)
  assignedToId     String?     @map("assigned_to_id")
  assignedTo       User?       @relation("JobAssignee", fields: [assignedToId], references: [id])
  openDate         DateTime?   @map("open_date")
  closeDate        DateTime?   @map("close_date")
  applicationCount Int         @default(0) @map("application_count")
  interviewCount   Int         @default(0) @map("interview_count")
  offerCount       Int         @default(0) @map("offer_count")
  placementCount   Int         @default(0) @map("placement_count")
  deletedAt        DateTime?   @map("deleted_at")
  updatedById      String?     @map("updated_by_id")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  applications JobApplication[]

  @@index([tenantId, status, deletedAt])
  @@index([tenantId, clientId])
  @@index([tenantId, ownerUserId])
  @@map("jobs")
}

// ---------------------------------------------------------------------------
// CRM — Client Contacts
// ---------------------------------------------------------------------------

/// HR contacts at a client company. Distinct from Candidate (avoids Gllue's type-discriminator collapse).
model ClientContact {
  id          String    @id
  tenantId    String    @map("tenant_id")
  clientId    String    @map("client_id")
  client      Client    @relation(fields: [clientId], references: [id])
  ownerUserId String?   @map("owner_user_id")
  createdById String?   @map("created_by_id")
  firstName   String    @map("first_name")
  lastName    String    @map("last_name")
  title       String?
  email       String?
  phone       String?
  isPrimary   Boolean   @default(false) @map("is_primary")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([tenantId, clientId])
  @@map("client_contacts")
}

// ---------------------------------------------------------------------------
// CRM — Candidate Resume Sub-Records
// ---------------------------------------------------------------------------

model CandidateExperience {
  id           String    @id
  tenantId     String    @map("tenant_id")
  candidateId  String    @map("candidate_id")
  candidate    Candidate @relation(fields: [candidateId], references: [id])
  company      String
  title        String
  location     String?
  startDate    DateTime? @map("start_date")
  endDate      DateTime? @map("end_date")
  isCurrent    Boolean   @default(false) @map("is_current")
  description  String?
  displayOrder Int       @default(0) @map("display_order")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([tenantId, candidateId])
  @@map("candidate_experiences")
}

model CandidateEducation {
  id           String    @id
  tenantId     String    @map("tenant_id")
  candidateId  String    @map("candidate_id")
  candidate    Candidate @relation(fields: [candidateId], references: [id])
  institution  String
  degree       String?
  field        String?
  startDate    DateTime? @map("start_date")
  endDate      DateTime? @map("end_date")
  displayOrder Int       @default(0) @map("display_order")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([tenantId, candidateId])
  @@map("candidate_educations")
}

model CandidateLanguage {
  id          String              @id
  tenantId    String              @map("tenant_id")
  candidateId String              @map("candidate_id")
  candidate   Candidate           @relation(fields: [candidateId], references: [id])
  language    String              // ISO 639-1: 'en', 'zh', 'fr', ...
  proficiency LanguageProficiency
  createdAt   DateTime            @default(now()) @map("created_at")

  @@unique([tenantId, candidateId, language])
  @@index([tenantId, candidateId])
  @@map("candidate_languages")
}

// ---------------------------------------------------------------------------
// CRM — Pipeline: Spine + Stage Tables
// ---------------------------------------------------------------------------

/// The pipeline spine — one row per (Candidate × Job).
/// Stage transitions live in ApplicationStage rows; this row caches the highest stage reached.
model JobApplication {
  id          String               @id
  tenantId    String               @map("tenant_id")
  candidateId String               @map("candidate_id")
  candidate   Candidate            @relation(fields: [candidateId], references: [id])
  jobId       String               @map("job_id")
  job         Job                  @relation(fields: [jobId], references: [id])
  source      String?              // 'manual' | 'linkedin' | 'portal' | 'referral'
  ownerUserId String?              @map("owner_user_id")
  maxStage    ApplicationStageType @default(APPLIED) @map("max_stage")
  isActive    Boolean              @default(true) @map("is_active")
  matchScore  Decimal?             @db.Decimal(5, 2) @map("match_score")
  deletedAt   DateTime?            @map("deleted_at")
  createdById String?              @map("created_by_id")
  updatedById String?              @map("updated_by_id")
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  stages     ApplicationStage[]
  interviews Interview[]
  offers     Offer[]
  placements Placement[]

  @@unique([tenantId, candidateId, jobId])
  @@index([tenantId, jobId, isActive])
  @@index([tenantId, maxStage])
  @@map("job_applications")
}

/// Append-only typed event log. One row per stage transition. Never update rows.
model ApplicationStage {
  id            String               @id
  tenantId      String               @map("tenant_id")
  applicationId String               @map("application_id")
  application   JobApplication       @relation(fields: [applicationId], references: [id])
  stage         ApplicationStageType
  enteredAt     DateTime             @default(now()) @map("entered_at")
  enteredById   String               @map("entered_by_id")
  note          String?

  @@index([tenantId, applicationId, enteredAt])
  @@map("application_stages")
}

model Interview {
  id                String         @id
  tenantId          String         @map("tenant_id")
  applicationId     String         @map("application_id")
  application       JobApplication @relation(fields: [applicationId], references: [id])
  round             Int
  scheduledAt       DateTime       @map("scheduled_at")
  completedAt       DateTime?      @map("completed_at")
  interviewerUserId String?        @map("interviewer_user_id")
  feedback          String?
  rating            Int?           // 1–5
  createdById       String         @map("created_by_id")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  @@index([tenantId, applicationId])
  @@map("interviews")
}

model Offer {
  id            String         @id
  tenantId      String         @map("tenant_id")
  applicationId String         @map("application_id")
  application   JobApplication @relation(fields: [applicationId], references: [id])
  amount        Decimal?       @db.Decimal(15, 2)
  currency      String?        @default("USD")
  signedAt      DateTime?      @map("signed_at")
  startDate     DateTime?      @map("start_date")
  declinedAt    DateTime?      @map("declined_at")
  declineReason String?        @map("decline_reason")
  createdById   String         @map("created_by_id")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@index([tenantId, applicationId])
  @@map("offers")
}

model Placement {
  id            String         @id
  tenantId      String         @map("tenant_id")
  applicationId String         @map("application_id")
  application   JobApplication @relation(fields: [applicationId], references: [id])
  startDate     DateTime?      @map("start_date")
  endDate       DateTime?      @map("end_date")
  salary        Decimal?       @db.Decimal(15, 2)
  currency      String?        @default("USD")
  fee           Decimal?       @db.Decimal(15, 2)
  feeType       FeeType?       @map("fee_type")
  notes         String?
  createdById   String         @map("created_by_id")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@index([tenantId, applicationId])
  @@map("placements")
}

// ---------------------------------------------------------------------------
// Gllue → Cura Migration Models
// ---------------------------------------------------------------------------

/// Idempotency map: every migrated Gllue record → Cura ULID.
/// On re-run: check here first; only create/update if missing or checksum changed.
model MigrationMapping {
  id          String   @id
  tenantId    String   @map("tenant_id")
  sourceTable String   @map("source_table") // Gllue table name: 'candidate', 'client', 'joborder', ...
  sourceId    String   @map("source_id")    // Gllue integer PK coerced to string
  targetModel String   @map("target_model") // Cura model name: 'Candidate', 'Client', 'Job', ...
  targetId    String   @map("target_id")    // Cura ULID
  checksum    String?                        // MD5 of serialized source row for change detection
  migratedAt  DateTime @default(now()) @map("migrated_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([sourceTable, sourceId, tenantId])
  @@index([targetModel, targetId])
  @@map("migration_mappings")
}

/// Per-table sync cursor. Tracks last successful sync time for incremental delta queries.
model MigrationSyncCursor {
  id              String   @id
  tenantId        String   @map("tenant_id")
  sourceTable     String   @map("source_table")
  lastSyncAt      DateTime @default(dbgenerated("'1970-01-01 00:00:00+00'")) @map("last_sync_at")
  lastProcessedId BigInt?  @map("last_processed_id")
  errorCount      Int      @default(0) @map("error_count")
  lastError       String?  @map("last_error")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, sourceTable])
  @@map("migration_sync_cursors")
}

/// Per-tenant migration state: controls read-only enforcement and cutover.
model MigrationConfig {
  id              String          @id
  tenantId        String          @unique @map("tenant_id")
  gllueSchemaName String?         @map("gllue_schema_name")
  status          MigrationStatus @default(ACTIVE)
  readOnly        Boolean         @default(true) @map("read_only")
  syncEnabled     Boolean         @default(true) @map("sync_enabled")
  cutoverDate     DateTime?       @map("cutover_date")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@map("migration_configs")
}

/// Marketing waitlist — email sign-ups captured from the home page.
model WaitlistEntry {
  id        String   @id
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("waitlist_entries")
}

/// Clerk-era audit trail — superseded by AuditLog for new events; retained for history.
model ActivityLog {
  id         String         @id
  tenantId   String         @map("tenant_id")
  tenant     Tenant         @relation(fields: [tenantId], references: [id])
  userId     String?        @map("user_id")
  user       User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     ActivityAction
  entityType String         @map("entity_type")
  entityId   String?        @map("entity_id")
  metadata   Json?
  createdAt  DateTime       @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@map("activity_logs")
}

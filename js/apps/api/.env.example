# Copy this file to .env and fill in your values
# For local dev, these match the values in infra/.env

DATABASE_URL="postgresql://cura:cura@localhost:5432/cura_dev"

# Clerk authentication (https://dashboard.clerk.com → API Keys)
CLERK_SECRET_KEY="sk_test_xxxx"
CLERK_PUBLISHABLE_KEY="pk_test_xxxx"

# Clerk Webhook (Clerk Dashboard → Webhooks → Signing Secret)
# Events to subscribe: organization.created, organization.updated,
# organizationMembership.created, organizationMembership.deleted, user.updated
CLERK_WEBHOOK_SECRET="whsec_xxxx"
